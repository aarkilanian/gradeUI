Saplings <-
read.csv("SaplingStudy.csv")
Saplings <-
na.omit(Saplings)
View(moosefinal)
View(Saplings)
sap_reg_browse <-
Saplings %>%
group_by(Ecoregion) %>%
summarize(mean(BrowsingScore)) %>%
print()
Saplings %>%
group_by(Ecoregion) %>%
summarize(mean(Height)) %>%
print()
View(sap_reg_browse)
sap_reg_browse <-
Saplings %>%
group_by(Ecoregion) %>%
summarize(AverageBrowsing =
mean(BrowsingScore)
) %>%
print()
avg_browse_reg <-
sap_reg_browse %>%
arrange(desc(AverageBrowsing)) %>%
print()
sap_reg_height <-
Saplings %>%
group_by(Ecoregion) %>%
summarize(AverageHeight =
mean(Height)
) %>%
print()
View(sap_reg_height)
sap_reg_height_low <-
sap_reg_height %>%
filter(AverageHeight < 20) %>%
print()
# The ecoregions shown above have average tree heights of 20 cm or less and are considered severely browsed by moose.
sap_spe_browse <-
Saplings %>%
group_by(Species) %>%
summarize(AverageBrowsing =
mean(BrowsingScore)
) %>%
print()
avg_browse_spe <-
sap_spe_browse %>%
arrange(desc(AverageBrowsing)) %>%
print()
# The species at the top of avg_browse_spe has the highest
# average browsing score.
# The species at the bottom has the lowest
# average browsing score.
A team of researchers in interested in how Balsam Fir browsing intensity varies by ecoregion. With the help of pipes %>%, use the filter() function to filter the Species column for only Balsam_Fir, then use group_by() function to sort by Ecoregion , and then determine mean() moose BrowsingScore. Save the resulting summary table as fir_reg_browse. HINT: Adapt the code from Question 12 above.
fir_reg_browse <-
Saplings %>%
filter(Species ==
"Balsam_Fir"
) %>%
group_by(Ecoregion) %>%
summarize(AverageBrowsing =
mean(BrowsingScore)
) %>%
print()
View(fir_reg_browse)
View(fir_reg_browse)
barplot(fir_reg_browse$AverageBrowsing,
names.arg = fir_reg_browse$Ecoregion,
xlab = "Ecoregion",
ylab = "Average Browsing Score",
main = "Balsam Fir Browsing Intensity by Ecoregion",
col = "forestgreen",
cex.names = 0.6)
spruce_reg_browse <-
Saplings %>%
filter(Species ==
"Black_Spruce"
) %>%
group_by(Ecoregion) %>%
summarize(AverageBrowsing =
mean(BrowsingScore)
) %>%
print()
barplot(spruce_reg_browse$AverageBrowsing,
names.arg = spruce_reg_browse$Ecoregion,
xlab = "Ecoregion",
ylab = "Average Browsing Score",
main = "Black Spruce Browsing Intensity by Ecoregion",
col = "forestgreen",
cex.names = 0.6)
# Black Spruce browsing intensity differs across ecoregions and may be higher or lower than Balsam Fir depending on the region.
# Comparing the two barplots shows how moose preference varies by species and location.
sap_reg_tally<- sap_clean %>%
group_by(Ecoregion) %>%
tally() %>%
print()
sap_reg_tally <-
Saplings %>%
group_by(Ecoregion) %>%
tally() %>%
print()
sap_spe_tally <-
Saplings %>%
group_by(Species) %>%
tally() %>%
print()
# a) The study could show uneven distribution across ecoregions and species. Some ecoregions and/or species may have more sampled trees, while others may have fewer observations, indicating potential overrepresentation or underrepresentation in a potential dataset.
# b) It is important to recognize bias in ecological datasets because uneven sampling can influence averages and lead to misleading info.
Overrepresented groups may disproportionately affect results and misrepresent true patterns.
moose_2020b <-
moose_clean %>%
filter(Year == 2020) %>%
mutate(MooseDensity =
Estimated_Moose_Pop / Area
)
moose_sap <-
left_join(moose_2020b, sap_clean,
by = 'Ecoregion',
relationship = "many-to-many")
moose_sap <-
left_join(moose_2020b, Saplings,
by = 'Ecoregion',
relationship = "many-to-many")
sum_spe_browse <-
moose_sap %>%
group_by(Species, Ecoregion) %>%
summarize(
AvgBrowsing = mean(BrowsingScore),
AvgDensity = mean(MooseDensity)
) %>%
print()
