#Question 15---------------------------------------------
fir_reg_browse <- sap_clean %>% filter(Species == "Balsam_Fir") %>% group_by(Ecoregion) %>% summarise(mean_BrowsingScore = mean(BrowsingScore)) %>% print()
View(fir_reg_browse)
#Question 16:--------------------------------------------------
barplot(fir_reg_browse$mean_BrowsingScore, names.arg = fir_reg_browse$Ecoregion, xlab = "Ecoregion",ylab = "Average browsing intensity",main = "Average Balsam Fir browsing intensity by ecoregion", col = "forestgreen", cex.names = 0.6)
#One of my fav. colors is forestgreen, so I left it. Need's full screen to view all labels, will adjust. Also Data extends to 4.5, graph y limits to 4, need to adjust.
barplot(fir_reg_browse$mean_BrowsingScore, names.arg = fir_reg_browse$Ecoregion, xlab = "Ecoregion", ylab = "Average browsing intensity", main = "Average Balsam Fir browsing intensity by ecoregion", col = "forestgreen", cex.names = 0.5, ylim = c(0, 5))
