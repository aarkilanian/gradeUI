#Question 18:--------------------------------------------------
sap_reg_tally <- sap_clean %>% group_by(Ecoregion) %>% tally() %>% print()
#Question 19:--------------------------------------------------
sap_spe_tally <- sap_clean %>% group_by(Species) %>% tally() %>% print()
#Question 20a:-------------------------------------------------
# The SaplingStudy dataset is not evenly distributed across species. Balsam Fir and Black Spruce are relatively well represented (11 & 9 respectively), while Black Ash is strongly underrepresented (only 1), which may create biased interpretations of moose browsing patterns toward more commonly sampled species.
#Question 20b:-------------------------------------------------
#Recognizing bias in ecological datasets is important because uneven sampling can lead to misleading conclusions about species interactions or ecosystems. Recognizing and adressing  bias helps ensure that observed patterns reflect the true dynamics of ecosystems and species.
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
#Question 21:--------------------------------------------------
View(moose_clean)
moose_2020b <- moose_clean %>% filter(Year == 2020) %>% mutate(MooseDensity = Estimated_Moose_Pop / Area)
View(moose_2020b)
#Question 21b:-------------------------------------------------
moose_sap <- left_join(moose_2020b, sap_clean, by = 'Ecoregion', relationship = "many-to-many")
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
#Question 22:--------------------------------------------------
sum_spe_browse <- moose_sap %>% group_by(Species, Ecoregion) %>% summarise(mean_BrowsingScore = mean(BrowsingScore), mean_MooseDensity = mean(MooseDensity)) %>% print()
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
#Question 23a:-------------------------------------------------
# The figure supports the hypothesis, as browsing intensity at low moose densities varies strongly among tree species,
indicating selective feeding on preferred species such as alder and willow. At higher moose densities, browsing scores increase across all species and become more similar in browsing score, suggesting a shift toward less selective, more uniform browsing due to increased competition.
#The figure supports the hypothesis, as browsing intensity at low moose densities varies strongly among tree species, indicating selective feeding on preferred species such as alder and willow. At higher moose densities, browsing scores increase across all species and become more similar in browsing score, suggesting a shift toward less selective, more uniform browsing due to increased competition.
#Question 23b:-------------------------------------------------
#Moose favor willow and alder the most, as they score highest across high and low moose densitys. Black ash and black spruce species are browsed the least across all densitys suggesting they are less preferred by moose.
View(sum_spe_browse)
#Question 23c:-------------------------------------------------------
#Black Ash is not shown in the figure because it was very underrepresented in the dataset (only one sampled sapling), making it not fit for calculating reliable average browsing scores across avg moose densities (one region, one sample, not very valid).
#Question 24:--------------------------------------------------------
collisions2020 <- c(56, 60, 14, 36, 48, 10, 40, 110, 6)
human_pop <- c(18000, 12000, 4000, 75100, 24000, 3500, 32000, 270000, 2300)
study_sites <- c("North_Shore_Forests", "Northern_Peninsula_Forests",
"Long_Range_Barrens", "Central_Forests", "Western_Forests", "EasternHyperOceanicBarrens", "Maritime_Barrens", "Avalon_Forests", "StraitOfBelleIsleBarrens")
study_sites <- c("North_Shore_Forests", "Northern_Peninsula_Forests","Long_Range_Barrens", "Central_Forests", "Western_Forests", "EasternHyperOceanicBarrens", "Maritime_Barrens", "Avalon_Forests", "StraitOfBelleIsleBarrens")
moose_coll <- data.frame(collisions2020, human_pop, study_sites)
#Question 25:--------------------------------------------------------
moose_coll2 <- moose_coll %>% rename_with("Ecoregion" = study_sites)
moose_coll2 <- moose_coll %>% rename_with(Ecoregion = study_sites)
moose_coll2 <- moose_coll %>% rename_with("Ecoregion" = "study_sites")
moose_coll2 <- moose_coll %>% rename_with("Ecoregion", study_sites)
moose_coll2 <- moose_coll %>% rename_with(~ "Ecoregion", study_sites)
names(moose_coll2)
#Question 25b:-------------------------------------------------------
coll_merge <- left_join(moose_coll2, moose_2020, by = "Ecoregion", relationship = "many-to-many")
#Question 26a:-------------------------------------------------------
plot(coll_merge$MooseDensity, coll_merge$collisions2020, xlab = "Moose Density (moose per sq km)", ylab = "Number of Moose-Vehicle Collisions ", main = "Moose Density vs Moose-Vehicle Collisions in 2020", pch = 16, col = "violetred")
plot(coll_merge$MooseDensity, coll_merge$collisions2020, xlab = "Moose Density (moose per sq km)", ylab = "Number of Moose-Vehicle Collisions ", main = "Moose Density vs Moose-Vehicle Collisions in 2020", pch = 16, col = "violetred")
#Used zoom to fix error of margins
#Question 26b:-------------------------------------------------------
View(coll_merge)
#The scatterplot suggests a general positive trend: ecoregions with higher moose densities tend to have more moose-vehicle collisions. There is an outlier around 1.0 moose density with a high number of collisions, likely the Avalon_Forests ecoregion, where higher human population in a smaller area increases moose-human encounters.
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
source("~/R_folder/BIOL_1002_R_assignment/ZachChaytor_BIOL1002_RAssignment.R")
#Question 27:-------------------------------------------------------
coll_merge_per_capita <- coll_merge %>% mutate(coll_per_capita = collisions2020 / human_pop)
#Question 28:--------------------------------------------------------
plot(coll_merge_per_capita$human_pop, coll_merge_per_capita$coll_per_capita, xlab = "Human Population", ylab = "Moose-Vehicle Collisions per Person", main = "Collisions per Capita vs Human Population", pch = 17, col = "turquoise3")
plot(coll_merge_per_capita$human_pop, coll_merge_per_capita$coll_per_capita, xlab = "Human Population", ylab = "Moose-Vehicle Collisions per Person", main = "Collisions per Capita vs Human Population", pch = 17, col = "turquoise3")
plot(coll_merge_per_capita$human_pop, coll_merge_per_capita$coll_per_capita, xlab = "Human Population", ylab = "Moose-Vehicle Collisions per Person", main = "Collisions per Capita vs Human Population", pch = 17, col = "turquoise3")
plot(coll_merge_per_capita$human_pop, coll_merge_per_capita$coll_per_capita, xlab = "Human Population", ylab = "Moose-Vehicle Collisions per Person", main = "Collisions per Capita vs Human Population", pch = 17, col = "turquoise3")
plot(coll_merge_per_capita$human_pop, coll_merge_per_capita$coll_per_capita, xlab = "Human Population", ylab = "Moose-Vehicle Collisions per Person", main = "Collisions per Capita vs Human Population", pch = 17, col = "turquoise3")
