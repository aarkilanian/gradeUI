# Create boxplot and save stats
bp <- boxplot(
control$width,
treatment$width,
names = c("control", "treatment"),
ylab = "Stomatal opening (u)",
ylim = c(6.8, 13)
)
stats <- bp$stats   # min, Q1, median, Q3, max
# Calculate approximate 95% CI for median
n <- c(length(control$width), length(treatment$width))
iqr <- stats[4,] - stats[2,]
se <- iqr / sqrt(n)
upper95 <- stats[3,] + 1.96 * se
lower95 <- stats[3,] - 1.96 * se
# Add labels neatly
for(i in 1:2){
# Median
arrows(i, stats[3,i], i + 0.2, stats[3,i], length = 0.08)
text(i + 0.25, stats[3,i], "median", pos = 4)
# Q1
arrows(i, stats[2,i], i + 0.2, stats[2,i], length = 0.08)
text(i + 0.25, stats[2,i], "25%", pos = 4)
# Q3
arrows(i, stats[4,i], i + 0.2, stats[4,i], length = 0.08)
text(i + 0.25, stats[4,i], "75%", pos = 4)
# 95% CI
arrows(i, lower95[i], i
