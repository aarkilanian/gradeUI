SaplingStudy <- read.csv("~/Downloads/SaplingStudy.csv")
View(SaplingStudy)
View(SaplingStudy)
View(SaplingStudy)
View(SaplingStudy)
# Remove rows with missing values
sap_clean <- na.omit(SaplingStudy)
library(dplyr)
# a) Mean browsing score by ecoregion
sap_reg_browse <- sap_clean %>%
group_by(Ecoregion) %>%
summarize(AverageBrowsing = mean(BrowsingScore, na.rm = TRUE)) %>%
print()
# Rearrange to see highest and lowest average browsing
avg_browse_reg <- sap_reg_browse %>%
arrange(desc(AverageBrowsing))
# Highest average browsing = first row
# Lowest average browsing = last row
library(dplyr)
# Mean tree height by ecoregion
sap_reg_height <- sap_clean %>%
group_by(Ecoregion) %>%
summarize(AverageHeight = mean(Height, na.rm = TRUE)) %>%
print()
# Ecoregions with average height < 20 cm (severely browsed)
sap_reg_height_low <- sap_reg_height %>%
filter(AverageHeight < 20) %>%
print()
# Ecoregions in sap_reg_height_low have average heights < 20 cm
library(dplyr)
# Mean browsing score by sapling species
sap_spe_browse <- sap_clean %>%
group_by(Species) %>%
summarize(AverageBrowsing = mean(BrowsingScore, na.rm = TRUE)) %>%
print()
# Rearrange to find highest and lowest browsing by species
avg_browse_spe <- sap_spe_browse %>%
arrange(desc(AverageBrowsing))
# Highest average browsing = first species in avg_browse_spe
# Lowest average browsing = last species in avg_browse_spe
library(dplyr)
fir_reg_browse <- sap_clean %>%
filter(Species == "Balsam_Fir") %>%
group_by(Ecoregion) %>%
summarize(AverageBrowsing = mean(BrowsingScore, na.rm = TRUE))
barplot(fir_reg_browse$AverageBrowsing,
names.arg = fir_reg_browse$Ecoregion,
xlab = "Ecoregion",
ylab = "Average Browsing Intensity",
main = "Average Balsam Fir Browsing Intensity by Ecoregion",
col = "forestgreen",
cex.names = 0.6)
library(dplyr)
# Mean browsing score for Black Spruce by ecoregion
spruce_reg_browse <- sap_clean %>%
filter(Species == "Black_Spruce") %>%
group_by(Ecoregion) %>%
summarize(AverageBrowsing = mean(BrowsingScore, na.rm = TRUE))
library(dplyr)
sap_reg_tally <- sap_clean %>%
group_by(Ecoregion) %>%
tally()
library(dplyr)
sap_spe_tally <- sap_clean %>%
group_by(Species) %>%
tally()
# a) The SaplingStudy dataset is not evenly distributed across ecoregions and species.
# Some ecoregions and tree species have higher sample sizes than others, meaning they
# are overrepresented, while others are underrepresented in the dataset.
# b) Recognizing bias in ecological datasets is important because uneven sampling can
# lead to misleading conclusions about species interactions and ecosystem patterns.
# Bias may cause certain trends to appear stronger or weaker than they truly are.
library(dplyr)
# Filter for year 2020 and calculate MooseDensity
moose_2020b <- moose_clean %>%
filter(Year == 2020) %>%
mutate(MooseDensity = Estimated_Moose_Pop / Area)
# Join with sapling data by Ecoregion
moose_sap <- left_join(moose_2020b, sap_clean, by = "Ecoregion")
library(dplyr)
sum_spe_browse <- moose_sap %>%
group_by(Species, Ecoregion) %>%
summarize(
AverageBrowsing = mean(BrowsingScore, na.rm = TRUE),
AverageMooseDensity = mean(MooseDensity, na.rm = TRUE)
) %>%
print()
# a) At low moose density, moose strongly prefer willow, but at higher densities,
# they browse all species more evenly. This supports the hypothesis that moose
# shift to generalist browsing at higher densities.
# b) Moose favor willow the most, as indicated by its high browsing score,
# especially at low moose densities. They browse black spruce the least, showing
# almost no browsing at low densities and only a little at high densities.
# c) Alder is not shown on the figure because moose do not browse it.
# Vectors
collisions2020 <- c(56, 60, 14, 36, 48, 10, 40, 110, 6)
human_pop <- c(18000, 12000, 4000, 75100, 24000, 3500, 32000, 270000, 2300)
study_sites <- c("North_Shore_Forests",
"Northern_Peninsula_Forests",
"Long_Range_Barrens",
"Central_Forests",
"Western_Forests",
"EasternHyperOceanicBarrens",
"Maritime_Barrens",
"Avalon_Forests",
"StraitOfBelleIsleBarrens")
# Create a data frame
moose_coll <- data.frame(collisions2020, human_pop, study_sites)
library(dplyr)
# Rename study_sites column to match moose_2020's Ecoregion column
moose_coll2 <- moose_coll %>%
rename(Ecoregion = study_sites)
# Join the datasets by Ecoregion
coll_merge <- left_join(moose_2020, moose_coll2, by = "Ecoregion")
# Scatterplot of MooseDensity vs. collisions2020
plot(coll_merge$MooseDensity,
coll_merge$collisions2020,
xlab = "Moose Density (moose per unit area)",
ylab = "Number of Moose-Vehicle Collisions (2020)",
main = "Relationship Between Moose Density and Vehicle Collisions",
pch = 19,
col = "darkblue")
# The plot shows that, generally, higher moose densities are associated with more collisions.
# There are a few potential outliers where collisions are unusually high relative to moose density,
# such as Avalon_Forests with very high human population and collision counts.
library(dplyr)
# Calculate collisions per capita
coll_merge_per_capita <- coll_merge %>%
mutate(coll_per_capita = collisions2020 / human_pop)
# Scatterplot of collisions per capita vs. human population
plot(coll_merge_per_capita$human_pop,
coll_merge_per_capita$coll_per_capita,
xlab = "Human Population",
ylab = "Moose-Vehicle Collisions per Capita",
main = "Collisions per Capita vs. Human Population",
pch = 19,
col = "darkred")
# The scatterplot shows that sites with smaller human populations tend to have higher
# collisions per capita, while more populous areas have lower per-person collision rates.
# This makes sense because moose are widespread in Newfoundland, so in sparsely populated
# regions each person is more likely to encounter a moose, leading to more collisions per capita.
