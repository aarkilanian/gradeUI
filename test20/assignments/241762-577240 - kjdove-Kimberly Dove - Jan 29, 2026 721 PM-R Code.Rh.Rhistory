install.packages("dplyr")
library(dplyr)
moose_clean <- na.omit(moosedata)
View(moose_clean)
library(dplyr)
moose_sel <- select(moose_clean, Ecoregion, Year, Area, Estimated_Moose_Pop)
# Oldest year in the dataset
year_min <- min(moose_sel$Year, na.rm = TRUE)
# Highest estimated moose population recorded
moose_max <- max(moose_sel$Estimated_Moose_Pop, na.rm = TRUE)
library(dplyr)
moosedata2 <- moose_sel %>%
mutate(MooseDensity = Estimated_Moose_Pop / Area)
plot(moosedata2$Year,
moosedata2$MooseDensity,
type = "l",
xlab = "Year",
ylab = "Moose Density (moose per unit area)",
main = "Changes in Moose Density Over Time")
library(dplyr)
# a) Filter for the Western Forests Ecoregion
moose_west <- moosedata2 %>%
filter(Ecoregion == "Western_Forests")
# b) Line graph of moose density over time in Western Forests
plot(moose_west$Year,
moose_west$MooseDensity,
type = "l",
xlab = "Year",
ylab = "Moose Density (moose per unit area)",
main = "Changes in Moose Density Over Time in Western Forests")
library(dplyr)
# Filter for the year 2020
moose_2020 <- moosedata2 %>%
filter(Year == 2020)
# Filter for high moose density (> 2.0 moose/km^2)
moose_2020_high <- moose_2020 %>%
filter(MooseDensity > 2.0)
# Arrange moose density in descending order
moose_2020_high_byD <- moose_2020_high %>%
arrange(desc(MooseDensity))
