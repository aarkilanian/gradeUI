coll_merge <- left_join(moose_2020, moose_coll2, by = 'Ecoregion', relationship = "many-to-many")
coll_merge <- left_join(moose2020, moose_coll2, by = 'Ecoregion', relationship = "many-to-many")
View(coll_merge)
plot(coll_merge$MooseDensity, coll_merge$collisions2020,
xlab = "Moose per sq km",
ylab = "Number of collisions",
main = "Moose Population Density and Vehicle Collisions")
# There is a trend of vehicle collisions happening more frequently when the moose population density is higher. However, there is an outlier of over 110 collisions occuring in the Avalon forests, where the moose population density is only approximately 0.962.
coll_merge_per_capita <- coll_merge %>%
mutate(coll_per_capita = collisions2020/human_pop)
View(coll_merge_per_capita)
plot(coll_merge$MooseDensity, coll_merge$collisions2020, %>%
plot(coll_merge_per_capita$MooseDensity, coll_merge_per_capita$coll_per_capita,
xlab = "Moose per sq km",
ylab = "Number of collisions per capita",
main = "Moose Population Densityand Vehicle Collisions per Capita")
plot(coll_merge_per_capita$MooseDensity, coll_merge_per_capita$coll_per_capita,
+      xlab = "Moose per sq km",
plot(coll_merge_per_capita$MooseDensity, coll_merge_per_capita$coll_per_capita,
xlab = "Moose per sq km",
ylab = "Number of collisions per capita",
main = "Moose Population Density and Vehicle Collisions per Capita")
# There is a noticeable trend of collisions per capita increasing as the moose population density increases. This makes sense, considering how collisions tend to happen more often in Newfoundland when there’s both more moose, and more people driving vehicles.
