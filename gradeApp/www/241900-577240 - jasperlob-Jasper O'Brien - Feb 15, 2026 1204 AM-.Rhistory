# The researches' hypothesis is supported, as the moose browsing is more varied for different tree species at lower densities, indicating the more frequently browsed species are preferred by moose. However, the different species have much more similar browsing at higher densities, indicating that the moose's browsing is more generalist here.
# Moose tend to prefer alder and willow tree more and prefer balsam fir and black spruce trees less.
# Black ash trees don't show up in the graph at all, as they only appear in the data table once, with that one entry overlapping with a willow entry at (2.50,5.0).
collisions2020 <- c(56, 60, 14, 36, 48, 10, 40, 110, 6)
human_pop <- c(18000, 12000, 4000, 75100, 24000,3500, 32000, 270000, 2300)
study_sites <- c("North_Shore_Forests","Northern_Peninsula_Forests", "Long_Range_Barrens","Central_Forests","Western_Forests","EasternHyperOceanicBarrens","Maritime_Barrens","Avalon_Forests","StraitOfBelleIsleBarrens")
moose_coll <- data.frame(collisions2020, human_pop, study_sites)
View(moose_coll)
moose_sel <- select(moose_clean, Ecoregion, Year, Area, Estimated_Moose_Pop)
moosedata2 <- mutate(moose_sel, MooseDensity = Estimated_Moose_Pop / Area)
moose2020 <- filter(moosedata2, Year == 2020)
View(moose2020)
moose_coll2 <- rename.with(moose_coll, Ecoregions = study_sites)
moose_coll2 <- moose_coll %>%
rename_with(Ecoregions = study_sites)
moose_coll2 <- moose_coll %>%
rename_with(Ecoregions = "study_sites")
